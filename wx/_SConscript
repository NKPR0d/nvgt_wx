Import("env")
import os

plugin_name = "nvgt_wx"
plugin_env = env.Clone()
wx_lib_path = os.path.join("lib")
wx_include = os.path.join("include")
wx_setup_h = os.path.join(wx_lib_path, "mswu")

if plugin_env["PLATFORM"] == "win32":
    plugin_env.Append(CPPPATH=[wx_include, wx_setup_h])
    plugin_env.Append(LIBPATH=[wx_lib_path])
    
    plugin_env.Append(LIBS=[
        "wxmsw33u_core", 
        "wxbase33u"
    ])
    
    plugin_env.Append(CPPDEFINES=[
        "UNICODE", "_UNICODE", 
        "WXUSINGDLL", 
        "__WXMSW__",
        # ANGELSCRIPT_DLL_MANUAL_IMPORT switches angelscript.h from
        # extern-function declarations to extern-function-pointer
        # declarations populated by prepare_plugin() at runtime.
        # nvgt_plugin.h sets this for every TU that includes it,
        # but the vendored scriptarray.cpp does not — so define it
        # at the build level for every source uniformly.
        "ANGELSCRIPT_DLL_MANUAL_IMPORT"
    ])

shared_lib = plugin_env.SharedLibrary(
    target="#release/lib/" + plugin_name,
    source=[
        "wx.cpp",
        "src/runtime.cpp",
        "src/helpers.cpp",
        "src/manager.cpp",
        "src/register.cpp",
        "src/scriptarray.cpp",
    ]
)

Return("shared_lib")